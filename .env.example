# ── Core ──────────────────────────────────────────────────────────────────────
# UGRC geocoding API key (https://developer.mapserv.utah.gov)
UGRC_API_KEY=

# ── Google Sheets (data source + sink) ─────────────────────────────────────────
# 1. Create a Google Cloud service account, enable the Google Sheets API.
# 2. Download its JSON key.
# 3. Share BOTH spreadsheets with the service account email:
#      - Candidate sheet  → Viewer
#      - Volunteer sheet   → Editor
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
# Paste the private_key from the JSON. Keep the \n escapes (one line).
GOOGLE_SERVICE_ACCOUNT_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# Spreadsheet IDs (the long string in the sheet URL between /d/ and /edit)
CANDIDATE_SHEET_ID=
VOLUNTEER_SHEET_ID=

# Tab names (optional — defaults shown)
# CANDIDATE_TAB=Candidates
# VOLUNTEER_CONFIG_TAB=Config
# VOLUNTEER_SUBMISSIONS_TAB=Submissions

# ── ArcGIS Feature Services ────────────────────────────────────────────────────
# Change these for a different state/client. Leave blank to use Utah defaults.
# ARCGIS_BASE=https://services1.arcgis.com/99lidPhWCzftIe9K/ArcGIS/rest/services
# PRECINCT_SVC_PATH=VistaBallotAreas/FeatureServer/0/query
# HOUSE_SVC_PATH=UtahHouseDistricts2022to2032/FeatureServer/0/query
# SENATE_SVC_PATH=UtahSenateDistricts2022to2032/FeatureServer/0/query
# CONGRESS_SVC_PATH=political_us_congress_districts_2026_to_2032/FeatureServer/0/query
# SCHOOL_BOARD_SVC_PATH=UtahSchoolBoardDistricts2022to2032/FeatureServer/0/query
# SCHOOL_DISTRICT_SVC_PATH=UtahSchoolDistrictBoundaries/FeatureServer/0/query

# ── Volunteer Capture (optional secondary destination) ─────────────────────────
# Every signup is written to the Submissions tab. If set, also POST the JSON
# here (Zapier, Make, n8n, or your own endpoint) for extra routing.
VOLUNTEER_WEBHOOK_URL=
# Optional HMAC-SHA256 secret — adds X-Webhook-Signature: sha256=<hex>.
VOLUNTEER_WEBHOOK_SECRET=

# ── Branding & Geography ───────────────────────────────────────────────────────
# Leave blank to use Utah defaults.
# CLIENT_NAME=Utah Civic Compact
# CLIENT_STATE=Utah
# CLIENT_STATE_ABBR=UT
# CLIENT_GEO_VIEWBOX=-114.05,36.99,-109.04,42.00
# CLIENT_MAP_CENTER_LAT=39.5
# CLIENT_MAP_CENTER_LNG=-111.5
# CLIENT_MAP_ZOOM=7
# CLIENT_TIMEZONE=America/Denver
